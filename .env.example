# 标记说明：
# [必填] 启动应用或核心能力必须提供，生产/共享环境需要替换模板值。
# [条件必填] 只在对应运行方式或功能启用时必须提供。
# [可选] 可以留空或使用默认值，按需要调整。

# 应用配置
# [必填] production、development 两种环境，分别对应生产环境、开发环境。
# production secure 为 true，development 为 false；本地开发保持 development。
NODE_ENV=development
# [条件必填: Docker] 应用容器暴露给宿主机的端口。
APP_PORT=30001
# [条件必填: Docker] Nginx 反向代理暴露给宿主机的端口。
NGINX_PORT=30002
# [可选] 允许访问审核后台接口的用户名或邮箱，多个值用英文逗号分隔；生产环境必须设置具体账号，不能留空。
MODERATION_ADMIN_ACCOUNTS=你的用户名或邮箱

# 认证令牌
# [必填] JWT 访问令牌签名密钥；生产/共享环境必须替换为随机长字符串。
ACCESS_SECRET=replace-with-a-long-random-access-secret
# [必填] 访问令牌有效期，单位秒。
ACCESS_EXPIRES_IN=900
# [必填] JWT 刷新令牌签名密钥；生产/共享环境必须替换为随机长字符串。
REFRESH_SECRET=replace-with-a-long-random-refresh-secret
# [必填] 刷新令牌有效期，单位秒。
REFRESH_EXPIRES_IN=2592000

# 安全开关
# [可选] Cookie 是否强制 Secure；生产 HTTPS 环境必须为 true，本地 HTTP 开发保持 false 或留空。
COOKIE_SECURE=false
# [可选] 是否信任 X-Forwarded-For 等代理头；仅在应用只接受可信反向代理流量时设为 true。
TRUST_PROXY=false
# [可选] 是否启用旧版 /api/v1 接口；默认关闭，除非确认兼容需要且已完成安全复核。
ENABLE_V1_API=false
# [可选] 允许访问审核后台接口的用户名或邮箱，多个值用英文逗号分隔。
MODERATION_ADMIN_ACCOUNTS=v2_admin
# [可选] 是否临时放开审核后台权限；生产环境必须保持 false。
MODERATION_ALLOW_ALL=false

# 宿主机本地开发连接 Oracle 的运行时配置。
# docker-compose 中的 Oracle 服务会把宿主机 5501 端口映射到容器 1521 端口。
# [条件必填: 本地开发] 宿主机访问 Oracle 的主机名。
ORACLE_HOST=localhost
# [条件必填: 本地开发] 宿主机访问 Oracle 的端口。
ORACLE_PORT=5501
# [可选] 兼容字段；当前连接池优先使用 ORACLE_SERVICE_NAME。
ORACLE_SID=
# [必填] Oracle PDB 服务名。
ORACLE_SERVICE_NAME=ORCLPDB1
# [必填] 应用 schema 用户。
ORACLE_USER=neko_app
# [必填] 应用 schema 密码；使用内置 v2 SQL 时必须保持与 SQL 中 neko_app 密码一致。
ORACLE_PASSWORD="NekoApp2026#"
# [可选] Oracle 连接池最小连接数。
ORACLE_POOL_MIN=2
# [可选] Oracle 连接池最大连接数。
ORACLE_POOL_MAX=10
# [可选] Oracle 连接池扩容步长。
ORACLE_POOL_INCREMENT=1

# Oracle 容器和初始化配置。
# Oracle 基础镜像：官方镜像需要登录 Oracle Registry，也可以切换到阿里云国内镜像。
# [条件必填: Docker/初始化] oracle19c 和 db-init 使用的 Oracle 镜像。
ORACLE_IMAGE=registry.cn-hangzhou.aliyuncs.com/zhuyijun/oracle:19c
# ORACLE_IMAGE=registry.cn-hangzhou.aliyuncs.com/zhuyijun/oracle:19c
# ORACLE_IMAGE=container-registry.oracle.com/database/enterprise:19.3.0.0
# [条件必填: Docker] Oracle 容器 1521 映射到宿主机的端口。
ORACLE_HOST_PORT=5501
# [条件必填: Docker] Oracle EM Express 映射到宿主机的端口。
ORACLE_EM_PORT=5500
# [条件必填: Docker/初始化] Oracle 容器 SYS/SYSTEM 密码，也是 db-init 连接数据库的密码。
ORACLE_PWD=NekoRoot2026Local
# [条件必填: 初始化] db-init 使用的 CDB 服务名。
ORACLE_SYS_SERVICE_NAME=ORCLCDB
# [条件必填: 初始化] db-init 用于判断应用 schema 是否已初始化的表名。
DB_INIT_CHECK_TABLE=N_USERS

# 仅 Docker 模式使用的覆盖配置，由 docker-compose.yml 注入到 app 容器。
# production secure 为 true，development 为 false。
# [条件必填: Docker] app 容器运行环境；完整 Docker 栈保持 production。
DOCKER_NODE_ENV=production
# [条件必填: Docker] app 容器内访问 Oracle 的服务名，使用内置 Compose 时不要改成 localhost。
DOCKER_ORACLE_HOST=oracle19c
# [条件必填: Docker] app 容器内访问 Oracle 的端口。
DOCKER_ORACLE_PORT=1521
# [条件必填: Docker] app 容器内访问 Redis 的连接串，使用内置 Compose 时不要改成 localhost。
DOCKER_REDIS_URL=redis://redis:6379
# [条件必填: Docker] app 容器内访问 Redis 的服务名。
DOCKER_REDIS_HOST=redis
# [条件必填: Docker] app 容器内访问 Redis 的端口。
DOCKER_REDIS_PORT=6379
# [条件必填: Docker] app 容器内的持久化存储目录。
DOCKER_STORAGE_PATH=/app/storage
# [可选: Docker/WebSocket] 浏览器访问 Docker app 时使用的 WebSocket 地址；留空表示跟随当前页面自动使用 ws:// 或 wss:// 同源地址。
# Cloudflare Tunnel、HTTPS 反向代理或 Nginx 入口建议留空，或显式填写 wss://你的域名/_ws。
DOCKER_PUBLIC_WS_URL=

# 文件存储。宿主机和本地运行时统一使用项目根目录下的 ./storage。
# [条件必填: 文件上传] 宿主机挂载的存储根目录。
STORAGE_ROOT_DIR=./storage
# [必填] 存储类型；当前模板使用本地文件系统。
STORAGE_TYPE=local
# [必填] 应用运行时写入文件的存储目录。
STORAGE_PATH=./storage
# [必填] 对外暴露本地存储文件的 URL 前缀。
STORAGE_PUBLIC_BASE=/storage
# [可选] CDN 或对象存储公开域名；本地存储可留空。
STORAGE_CDN_BASE_URL=
# [可选] 应用公开基础 URL；需要生成绝对链接时填写。
BASE_URL=

# Redis
# [可选] Redis 连接串；设置后 Redis 工具优先使用它。
REDIS_URL=
# [条件必填: 本地开发] 宿主机访问 Redis 的主机名。
REDIS_HOST=localhost
# [条件必填: 本地开发] 宿主机访问 Redis 的端口。
REDIS_PORT=6379
# [可选] Redis 数据库编号。
REDIS_DB=0
# [条件必填: 内置 Redis] Redis 密码；内置 redis 服务和健康检查会读取该值。
REDIS_PASSWORD=NekoRedis2026Local

# SMTP。邮箱验证码流程需要配置。
# [条件必填: 邮件功能] SMTP 主机；注册验证码、密码重置和账号邮件需要真实 SMTP。
SMTP_HOST=smtp.163.com
# [条件必填: 邮件功能] SMTP 端口；当前代码按安全 SMTP 创建连接。
SMTP_PORT=465
# [条件必填: 邮件功能] SMTP 用户名和发件人。
SMTP_USER=
# [条件必填: 邮件功能] SMTP 密码、授权码或应用专用密码。
SMTP_PASS=

# 客户端公开运行时配置
# [可选: WebSocket] 客户端使用的公开 WebSocket 地址；留空表示同源 /_ws。
# HTTPS 页面不能使用 ws://，需要使用 wss:// 或保持留空自动跟随当前页面协议。
NUXT_PUBLIC_WS_URL=
# [可选: Nuxt dev/HMR] 只有把 yarn dev 通过 HTTPS/Cloudflare Tunnel 暴露时才需要；本地开发留空。
NUXT_DEV_HMR_PROTOCOL=
NUXT_DEV_HMR_HOST=
NUXT_DEV_HMR_CLIENT_PORT=
# [可选] 客户端 API 基础地址；留空表示同源。
NUXT_PUBLIC_API_BASE=

# SentimentFlow 外部情感分析服务。
# 默认由 SENTIMENTFLOW_HOST_PORT / SENTIMENTFLOW_CONTAINER_PORT 派生访问地址。
# SENTIMENTFLOW_BASE_URL 仅用于接入外部 SentimentFlow 服务；留空时使用 http://localhost:${SENTIMENTFLOW_HOST_PORT}/api。
# docker-compose.yml 拉取 GHCR 镜像；docker-compose.local.yml 从 GitHub 拉取源码并构建。
# [可选] 让 Compose 能用 SENTIMENTFLOW_ENABLED=true 选择可选服务；不要改成 false。
COMPOSE_PROFILES=true
# [可选] 是否启用 SentimentFlow 集成和代理访问。
SENTIMENTFLOW_ENABLED=false
# [可选] 外部 SentimentFlow API 地址；留空时由端口配置派生。
SENTIMENTFLOW_BASE_URL=
# [可选] SentimentFlow 代理超时时间，单位毫秒。
SENTIMENTFLOW_TIMEOUT_MS=10000
# [条件必填: SentimentFlow/Docker] GHCR 后端镜像。
SENTIMENTFLOW_IMAGE=ghcr.io/cthaat/sentimentflow-backend:latest
# [条件必填: SentimentFlow/本地构建] 本地构建的后端镜像名。
SENTIMENTFLOW_LOCAL_IMAGE=sentimentflow-backend:local
# [条件必填: SentimentFlow/Docker] GHCR 前端镜像。
SENTIMENTFLOW_FRONTEND_IMAGE=ghcr.io/cthaat/sentimentflow-frontend:latest
# [条件必填: SentimentFlow/本地构建] 本地构建的前端镜像名。
SENTIMENTFLOW_FRONTEND_LOCAL_IMAGE=sentimentflow-frontend:local
# [条件必填: SentimentFlow/本地构建] 本地构建时拉取源码的仓库地址。
SENTIMENTFLOW_GIT_REPO=https://github.com/Cthaat/SentimentFlow.git
# [条件必填: SentimentFlow/本地构建] 本地构建时使用的 Git 分支或 tag。
SENTIMENTFLOW_GIT_REF=main
# [可选] Python 依赖镜像源。
SENTIMENTFLOW_PIP_INDEX_URL=https://pypi.org/simple
# [可选] PyTorch 安装源。
SENTIMENTFLOW_TORCH_INDEX_URL=https://pypi.org/simple
# [可选] PyTorch 包名；需要 GPU/CUDA 变体时再调整。
SENTIMENTFLOW_TORCH_PACKAGE=torch
# [可选] 暴露给 SentimentFlow 后端容器的 GPU 设备。
SENTIMENTFLOW_GPUS=all
# [可选] NVIDIA 容器运行时能力。
SENTIMENTFLOW_NVIDIA_DRIVER_CAPABILITIES=compute,utility
# [条件必填: SentimentFlow] SentimentFlow 容器内项目根目录。
SENTIMENTFLOW_CONTAINER_PROJECT_ROOT=/workspace
# [条件必填: SentimentFlow] SentimentFlow 容器内模型目录。
SENTIMENTFLOW_MODELS_DIR=/workspace/models
# [条件必填: SentimentFlow/Docker] SentimentFlow 后端映射到宿主机的端口。
SENTIMENTFLOW_HOST_PORT=8846
# [条件必填: SentimentFlow/Docker] SentimentFlow 后端容器内监听端口。
SENTIMENTFLOW_CONTAINER_PORT=8846
# [条件必填: SentimentFlow/Docker] SentimentFlow 前端映射到宿主机的端口。
SENTIMENTFLOW_FRONTEND_HOST_PORT=30008
# [条件必填: SentimentFlow/Docker] SentimentFlow 前端容器内监听端口。
SENTIMENTFLOW_FRONTEND_CONTAINER_PORT=3000

# 其他配置项
# [可选] Oracle 客户端字符集。
NLS_LANG=AMERICAN_AMERICA.AL32UTF8

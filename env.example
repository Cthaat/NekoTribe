# 此文件仅为向后兼容保留。
# 新环境优先复制 .env.example：
#   cp .env.example .env

# 应用配置
NODE_ENV=development
APP_PORT=30001
NGINX_PORT=30002

# 认证令牌
ACCESS_SECRET=replace-with-a-long-random-access-secret
ACCESS_EXPIRES_IN=900
REFRESH_SECRET=replace-with-a-long-random-refresh-secret
REFRESH_EXPIRES_IN=2592000

# 宿主机本地开发连接 Oracle 的运行时配置。
# docker-compose 中的 Oracle 服务会把宿主机 5501 端口映射到容器 1521 端口。
ORACLE_HOST=localhost
ORACLE_PORT=5501
ORACLE_SID=
ORACLE_SERVICE_NAME=ORCLPDB1
ORACLE_USER=neko_app
ORACLE_PASSWORD="NekoApp2026#"
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1

# Oracle 容器和初始化配置。
# Oracle 基础镜像：官方镜像需要登录 Oracle Registry，也可以切换到阿里云国内镜像。
ORACLE_IMAGE=container-registry.oracle.com/database/enterprise:19.3.0.0
# ORACLE_IMAGE=registry.cn-hangzhou.aliyuncs.com/zhuyijun/oracle:19c
ORACLE_HOST_PORT=5501
ORACLE_EM_PORT=5500
ORACLE_PWD=NekoRoot2026Local
ORACLE_SYS_SERVICE_NAME=ORCLCDB
DB_INIT_CHECK_TABLE=N_USERS

# 仅 Docker 模式使用的覆盖配置，由 docker-compose.yml 注入到 app 容器。
DOCKER_NODE_ENV=production
DOCKER_ORACLE_HOST=oracle19c
DOCKER_ORACLE_PORT=1521
DOCKER_REDIS_URL=redis://redis:6379
DOCKER_REDIS_HOST=redis
DOCKER_REDIS_PORT=6379
DOCKER_STORAGE_PATH=/app/storage
DOCKER_PUBLIC_WS_URL=ws://localhost:30001/_ws

# 文件存储。宿主机和本地运行时统一使用项目根目录下的 ./storage。
STORAGE_ROOT_DIR=./storage
STORAGE_TYPE=local
STORAGE_PATH=./storage
STORAGE_PUBLIC_BASE=/storage
STORAGE_CDN_BASE_URL=
BASE_URL=

# Redis
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=NekoRedis2026Local

# SMTP。邮箱验证码流程需要配置。
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# 客户端公开运行时配置
NUXT_PUBLIC_WS_URL=ws://localhost:3000/_ws
NUXT_PUBLIC_API_BASE=
